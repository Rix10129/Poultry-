{
  "name": "poultry-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "PRISMA_CLIENT_ENGINE_TYPE=wasm prisma generate && PRISMA_CLIENT_ENGINE_TYPE=wasm next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "db:generate": "PRISMA_CLIENT_ENGINE_TYPE=wasm prisma generate",
    "db:migrate": "prisma migrate dev",
